# Modelscope API token — get yours at https://modelscope.ai/my-access-token
# Your account must be linked to Alibaba Cloud with real-name verification
MODELSCOPE_API_TOKEN=ms-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API base URL (default: https://api-inference.modelscope.ai/v1/)
# Use .ai for international users, .cn for mainland China
MODELSCOPE_BASE_URL=https://api-inference.modelscope.ai/v1/

# Model to use (default: Qwen/Qwen2.5-72B-Instruct)
MODELSCOPE_MODEL=Qwen/Qwen2.5-72B-Instruct

# Working directory for file operations (default: .)
WORKSPACE_DIR=.
